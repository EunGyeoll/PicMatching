# Supabase 프로젝트 설정 > API 메뉴에서 값을 확인할 수 있습니다.
# 이 파일에는 실제 값을 채우지 말고, 로컬에서는 .env.local 파일을 별도로 만들어 사용하세요.

# Supabase 프로젝트 URL (공개)
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon(public) 키 — 브라우저에 노출되어도 되는 키입니다.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service_role 키 — 절대 클라이언트에 노출하지 마세요. 서버 전용입니다.
SUPABASE_SERVICE_ROLE_KEY=
